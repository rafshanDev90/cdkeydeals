"use client";

import { useState, useEffect } from "react";
import Link from "next/link";
import {
  Search,
  ShoppingCart,
  User,
  Menu,
  X,
  ChevronDown,
  ChevronRight,
  Gamepad2,
  Monitor,
  Gift,
  Tag,
  Flame,
  Moon,
  MapPin,
  TrendingUp,
  HelpCircle,
  BookOpen,
  MoreHorizontal,
} from "lucide-react";

const navCategories = {
  games: [
    { name: "Steam Keys", slug: "steam-keys" },
    { name: "Xbox Live Keys", slug: "xbox-keys" },
    { name: "PlayStation Keys", slug: "playstation-keys" },
    { name: "Nintendo Keys", slug: "nintendo-keys" },
    { name: "Epic Games Keys", slug: "epic-games" },
    { name: "UPlay Keys", slug: "uplay" },
    { name: "Origin Keys", slug: "origin" },
    { name: "Battle.net Keys", slug: "battle-net" },
  ],
  software: [
    { name: "Windows", slug: "windows" },
    { name: "Microsoft Office", slug: "microsoft-office" },
    { name: "Adobe Software", slug: "adobe" },
    { name: "Antivirus", slug: "antivirus" },
    { name: "VPN", slug: "vpn" },
  ],
  giftCards: [
    { name: "Steam Wallet", slug: "steam-wallet" },
    { name: "PlayStation Store", slug: "psn-cards" },
    { name: "Xbox Gift Cards", slug: "xbox-gift-cards" },
    { name: "Nintendo eShop", slug: "nintendo-eshop" },
    { name: "iTunes", slug: "itunes" },
    { name: "Google Play", slug: "google-play" },
    { name: "Amazon", slug: "amazon" },
    { name: "Spotify", slug: "spotify" },
  ],
  bestDeals: [
    { name: "Flash Sales", slug: "flash-sales" },
    { name: "Weekly Deals", slug: "weekly-deals" },
    { name: "Clearance", slug: "clearance" },
    { name: "Bundle Deals", slug: "bundles" },
  ],
  more: [
    { name: "About Us", slug: "about" },
    { name: "Contact", slug: "contact" },
    { name: "Support", slug: "support" },
    { name: "Affiliate Program", slug: "affiliate" },
  ],
};

const allProductsCategories = [
  { name: "Game Keys", icon: Gamepad2, items: navCategories.games },
  { name: "Software Keys", icon: Monitor, items: navCategories.software },
  { name: "Gift Cards", icon: Gift, items: navCategories.giftCards },
  { name: "Deals", icon: Tag, items: [{ name: "Hot Deals", slug: "deals" }, { name: "Flash Sale", slug: "flash-sale" }] },
];

export default function Header() {
  const [isScrolled, setIsScrolled] = useState(false);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [expandedMobileCategory, setExpandedMobileCategory] = useState<string | null>(null);
  const [searchQuery, setSearchQuery] = useState("");
  const [cartCount] = useState(2);
  const [isDarkMode, setIsDarkMode] = useState(false);

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 10);
    };
    window.addEventListener("scroll", handleScroll);
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  useEffect(() => {
    if (isMobileMenuOpen) {
      document.body.style.overflow = "hidden";
    } else {
      document.body.style.overflow = "unset";
    }
    return () => {
      document.body.style.overflow = "unset";
    };
  }, [isMobileMenuOpen]);

  const toggleMobileCategory = (categoryName: string) => {
    setExpandedMobileCategory(
      expandedMobileCategory === categoryName ? null : categoryName
    );
  };

  return (
    <>
      {/* Main Header - Sticky */}
      <header
        className={`sticky top-0 z-50 bg-white transition-shadow duration-300 ${
          isScrolled ? "shadow-lg" : "shadow-sm"
        }`}
      >
        {/* Top Bar */}
        <div className="border-b border-gray-100">
          <div className="container mx-auto px-4">
            <div className="flex items-center h-16 gap-4">
              {/* Left Side: Menu + Logo */}
              <div className="flex items-center gap-3">
                {/* Menu Button */}
                <button
                  onClick={() => setIsMobileMenuOpen(true)}
                  className="flex items-center gap-2 px-3 py-2 text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-all duration-200 hover:scale-105"
                  aria-label="Open menu"
                >
                  <Menu className="w-5 h-5" />
                  <span className="hidden sm:inline text-sm font-medium">Menu</span>
                </button>

                {/* Logo */}
                <Link href="/" className="flex items-center gap-2 shrink-0 group">
                  <div className="w-9 h-9 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow duration-200">
                    <span className="text-white font-bold text-lg">CD</span>
                  </div>
                  <span className="hidden md:block text-xl font-bold text-gray-900">
                    cdkey<span className="text-indigo-600">Deals</span>
                  </span>
                </Link>
              </div>

              {/* Search Bar with Category Dropdown */}
              <div className="flex-1 max-w-2xl hidden md:block">
                <div className="relative flex">
                  {/* Category Dropdown */}
                  <div className="relative group">
                    <button className="flex items-center gap-2 h-11 px-4 bg-gray-100 border border-r-0 border-gray-200 rounded-l-lg text-gray-700 hover:bg-gray-200 transition-colors">
                      <span className="text-sm font-medium">All products</span>
                      <ChevronDown className="w-4 h-4" />
                    </button>
                  </div>
                  
                  {/* Search Input */}
                  <div className="flex-1 relative">
                    <input
                      type="text"
                      placeholder="Search for anything..."
                      value={searchQuery}
                      onChange={(e) => setSearchQuery(e.target.value)}
                      className="w-full h-11 bg-white border border-gray-200 py-2.5 pl-4 pr-12 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all"
                    />
                    <button className="absolute right-0 top-0 h-11 px-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-r-lg transition-colors duration-200 hover:scale-105 active:scale-95">
                      <Search className="w-5 h-5" />
                    </button>
                  </div>
                </div>
              </div>

              {/* Right Side Icons */}
              <div className="flex items-center gap-1">
                {/* Search Icon (Mobile) */}
                <button className="md:hidden p-2.5 text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-all duration-200 hover:scale-105">
                  <Search className="w-5 h-5" />
                </button>

                {/* Login */}
                <Link
                  href="/login"
                  className="flex items-center gap-2 px-3 py-2 text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-all duration-200 hover:scale-105"
                >
                  <User className="w-5 h-5" />
                  <span className="hidden sm:inline text-sm font-medium">Login</span>
                </Link>

                {/* Cart */}
                <Link
                  href="/cart"
                  className="relative flex items-center gap-2 px-3 py-2 text-gray-700 hover:text-indigo-600 hover:bg-gray-50 rounded-lg transition-all duration-200 hover:scale-105"
                >
                  <ShoppingCart className="w-5 h-5" />
                  {cartCount > 0 && (
                    <span className="absolute top-0.5 right-0.5 w-5 h-5 bg-indigo-600 text-white text-xs font-bold rounded-full flex items-center justify-center animate-pulse">
                      {cartCount}
                    </span>
                  )}
                </Link>
              </div>
            </div>
          </div>
        </div>

        {/* Main Navigation Bar */}
        <div className="hidden lg:block border-b border-gray-100 bg-gray-50/50">
          <div className="container mx-auto px-4">
            <div className="flex items-center justify-between h-12">
              {/* Navigation Links */}
              <nav className="flex items-center gap-1">
                {/* Sale - Highlighted */}
                <Link
                  href="/sale"
                  className="flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-orange-500 to-red-500 rounded-lg hover:from-orange-600 hover:to-red-600 transition-all duration-200 hover:scale-105 hover:shadow-md"
                >
                  <Flame className="w-4 h-4" />
                  Sale
                </Link>

                {/* Games Dropdown */}
                <div className="relative group">
                  <button className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                    <Gamepad2 className="w-4 h-4" />
                    Games
                    <ChevronDown className="w-3.5 h-3.5 transition-transform group-hover:rotate-180" />
                  </button>
                  <div className="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                    <div className="w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-2 animate-dropdown">
                      {navCategories.games.map((item) => (
                        <Link
                          key={item.slug}
                          href={`/games/${item.slug}`}
                          className="flex items-center px-4 py-2.5 text-sm text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        >
                          {item.name}
                        </Link>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Software Dropdown */}
                <div className="relative group">
                  <button className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                    <Monitor className="w-4 h-4" />
                    Software
                    <ChevronDown className="w-3.5 h-3.5 transition-transform group-hover:rotate-180" />
                  </button>
                  <div className="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                    <div className="w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-2 animate-dropdown">
                      {navCategories.software.map((item) => (
                        <Link
                          key={item.slug}
                          href={`/software/${item.slug}`}
                          className="flex items-center px-4 py-2.5 text-sm text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        >
                          {item.name}
                        </Link>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Gift Cards Dropdown */}
                <div className="relative group">
                  <button className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                    <Gift className="w-4 h-4" />
                    Gift Cards
                    <ChevronDown className="w-3.5 h-3.5 transition-transform group-hover:rotate-180" />
                  </button>
                  <div className="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                    <div className="w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-2 animate-dropdown">
                      {navCategories.giftCards.map((item) => (
                        <Link
                          key={item.slug}
                          href={`/gift-cards/${item.slug}`}
                          className="flex items-center px-4 py-2.5 text-sm text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        >
                          {item.name}
                        </Link>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Best Deals Dropdown */}
                <div className="relative group">
                  <button className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                    <Tag className="w-4 h-4" />
                    Best Deals
                    <ChevronDown className="w-3.5 h-3.5 transition-transform group-hover:rotate-180" />
                  </button>
                  <div className="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                    <div className="w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-2 animate-dropdown">
                      {navCategories.bestDeals.map((item) => (
                        <Link
                          key={item.slug}
                          href={`/deals/${item.slug}`}
                          className="flex items-center px-4 py-2.5 text-sm text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        >
                          {item.name}
                        </Link>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Best Seller */}
                <Link
                  href="/best-seller"
                  className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200"
                >
                  <TrendingUp className="w-4 h-4" />
                  Best Seller
                </Link>

                {/* FAQ */}
                <Link
                  href="/faq"
                  className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200"
                >
                  <HelpCircle className="w-4 h-4" />
                  FAQ
                </Link>

                {/* Blog */}
                <Link
                  href="/blog"
                  className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200"
                >
                  <BookOpen className="w-4 h-4" />
                  Blog
                </Link>

                {/* More Dropdown */}
                <div className="relative group">
                  <button className="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                    <MoreHorizontal className="w-4 h-4" />
                    More
                    <ChevronDown className="w-3.5 h-3.5 transition-transform group-hover:rotate-180" />
                  </button>
                  <div className="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                    <div className="w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-2 animate-dropdown">
                      {navCategories.more.map((item) => (
                        <Link
                          key={item.slug}
                          href={`/${item.slug}`}
                          className="flex items-center px-4 py-2.5 text-sm text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        >
                          {item.name}
                        </Link>
                      ))}
                    </div>
                  </div>
                </div>
              </nav>

              {/* Right Side Utilities */}
              <div className="flex items-center gap-2">
                {/* Location/Currency Selector */}
                <button className="flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200">
                  <MapPin className="w-4 h-4" />
                  <span className="font-medium">Bangladesh</span>
                  <span className="text-gray-400">BDT</span>
                </button>

                {/* Dark Mode Toggle */}
                <button
                  onClick={() => setIsDarkMode(!isDarkMode)}
                  className="flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-indigo-600 rounded-lg hover:bg-white transition-all duration-200 hover:scale-105"
                  aria-label="Toggle dark mode"
                >
                  <Moon className="w-4 h-4" />
                  <span className="font-medium">Dark Mode</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        {/* Mobile Search Bar */}
        <div className="md:hidden border-b border-gray-100 px-4 py-3">
          <div className="relative flex">
            <button className="flex items-center gap-2 h-10 px-3 bg-gray-100 border border-r-0 border-gray-200 rounded-l-lg text-gray-700 text-sm">
              All
              <ChevronDown className="w-3.5 h-3.5" />
            </button>
            <input
              type="text"
              placeholder="Search..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="flex-1 h-10 bg-white border border-gray-200 px-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-indigo-500"
            />
            <button className="h-10 px-4 bg-indigo-600 text-white rounded-r-lg">
              <Search className="w-4 h-4" />
            </button>
          </div>
        </div>
      </header>

      {/* Mobile Menu Overlay */}
      {isMobileMenuOpen && (
        <div
          className="fixed inset-0 bg-black/50 z-50 backdrop-blur-sm"
          onClick={() => setIsMobileMenuOpen(false)}
        />
      )}

      {/* Mobile Sidebar Menu */}
      <div
        className={`fixed top-0 left-0 h-full w-[320px] max-w-[85vw] bg-white z-50 transform transition-transform duration-300 ease-out overflow-hidden ${
          isMobileMenuOpen ? "translate-x-0" : "-translate-x-full"
        }`}
      >
        <div className="flex flex-col h-full">
          {/* Sidebar Header */}
          <div className="flex items-center justify-between p-4 border-b border-gray-200 bg-gradient-to-r from-indigo-500 to-purple-600">
            <Link
              href="/"
              className="flex items-center gap-2"
              onClick={() => setIsMobileMenuOpen(false)}
            >
              <div className="w-8 h-8 bg-white/20 backdrop-blur rounded-lg flex items-center justify-center">
                <span className="text-white font-bold">CD</span>
              </div>
              <span className="text-lg font-bold text-white">
                cdkeyDeals
              </span>
            </Link>
            <button
              onClick={() => setIsMobileMenuOpen(false)}
              className="p-2 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
              aria-label="Close menu"
            >
              <X className="w-5 h-5" />
            </button>
          </div>

          {/* Sidebar Navigation */}
          <nav className="flex-1 overflow-y-auto">
            {/* Sale Link */}
            <Link
              href="/sale"
              onClick={() => setIsMobileMenuOpen(false)}
              className="flex items-center gap-3 px-4 py-4 text-white bg-gradient-to-r from-orange-500 to-red-500 font-semibold"
            >
              <Flame className="w-5 h-5" />
              Sale
            </Link>

            {allProductsCategories.map((category) => (
              <div key={category.name} className="border-b border-gray-100">
                <button
                  onClick={() => toggleMobileCategory(category.name)}
                  className="w-full flex items-center justify-between px-4 py-4 text-gray-900 hover:bg-gray-50 transition-colors"
                >
                  <span className="flex items-center gap-3">
                    <category.icon className="w-5 h-5 text-indigo-600" />
                    <span className="font-medium">{category.name}</span>
                  </span>
                  <ChevronRight
                    className={`w-5 h-5 text-gray-400 transition-transform duration-200 ${
                      expandedMobileCategory === category.name ? "rotate-90" : ""
                    }`}
                  />
                </button>

                <div
                  className={`overflow-hidden transition-all duration-200 ${
                    expandedMobileCategory === category.name
                      ? "max-h-96 opacity-100"
                      : "max-h-0 opacity-0"
                  }`}
                >
                  <div className="bg-gray-50 py-2">
                    {category.items.map((item) => (
                      <Link
                        key={item.slug}
                        href={`/${item.slug}`}
                        onClick={() => setIsMobileMenuOpen(false)}
                        className="block px-4 py-2.5 pl-12 text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                      >
                        {item.name}
                      </Link>
                    ))}
                  </div>
                </div>
              </div>
            ))}

            {/* Additional Links */}
            <div className="py-2">
              <Link
                href="/best-seller"
                onClick={() => setIsMobileMenuOpen(false)}
                className="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50"
              >
                <TrendingUp className="w-5 h-5 text-indigo-600" />
                <span className="font-medium">Best Seller</span>
              </Link>
              <Link
                href="/faq"
                onClick={() => setIsMobileMenuOpen(false)}
                className="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50"
              >
                <HelpCircle className="w-5 h-5 text-indigo-600" />
                <span className="font-medium">FAQ</span>
              </Link>
              <Link
                href="/blog"
                onClick={() => setIsMobileMenuOpen(false)}
                className="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50"
              >
                <BookOpen className="w-5 h-5 text-indigo-600" />
                <span className="font-medium">Blog</span>
              </Link>
            </div>
          </nav>

          {/* Sidebar Footer */}
          <div className="border-t border-gray-200 p-4 space-y-3">
            {/* Location Selector */}
            <button className="w-full flex items-center justify-between px-4 py-3 bg-gray-50 rounded-lg text-gray-700">
              <span className="flex items-center gap-2">
                <MapPin className="w-4 h-4 text-indigo-600" />
                <span className="font-medium">Bangladesh</span>
              </span>
              <span className="text-gray-500">BDT</span>
            </button>

            {/* Dark Mode Toggle */}
            <button
              onClick={() => setIsDarkMode(!isDarkMode)}
              className="w-full flex items-center justify-between px-4 py-3 bg-gray-50 rounded-lg text-gray-700"
            >
              <span className="flex items-center gap-2">
                <Moon className="w-4 h-4 text-indigo-600" />
                <span className="font-medium">Dark Mode</span>
              </span>
              <div className={`w-10 h-6 rounded-full transition-colors ${isDarkMode ? 'bg-indigo-600' : 'bg-gray-300'}`}>
                <div className={`w-5 h-5 mt-0.5 rounded-full bg-white shadow transition-transform ${isDarkMode ? 'translate-x-4.5 ml-0.5' : 'translate-x-0.5'}`} />
              </div>
            </button>

            {/* Login Button */}
            <Link
              href="/login"
              onClick={() => setIsMobileMenuOpen(false)}
              className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-medium rounded-lg transition-all duration-200 shadow-md hover:shadow-lg"
            >
              <User className="w-5 h-5" />
              Login
            </Link>
          </div>
        </div>
      </div>

      {/* CSS for dropdown animation */}
      <style jsx global>{`
        @keyframes dropdown {
          from {
            opacity: 0;
            transform: translateY(-8px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        .animate-dropdown {
          animation: dropdown 0.2s ease-out;
        }
      `}</style>
    </>
  );
}
